{
  "name": "player",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && (electron-builder --win --config electron-builder.yml || true) && cd release && rm -f UMKA-Kiosk-win.zip && zip -r UMKA-Kiosk-win.zip win-unpacked",
    "build:linux": "tsc && vite build && electron-builder --linux --config electron-builder.yml",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "mqtt": "^5.14.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.23",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1"
  },
  "main": "dist-electron/main.js",
  "pnpm": {
    "overrides": {
      "ip-address@<=10.1.0": ">=10.1.1",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "picomatch@<2.3.2": ">=2.3.2",
      "flatted@<=3.4.1": ">=3.4.2",
      "tar@<=7.5.10": ">=7.5.11",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "@xmldom/xmldom@<0.8.13": ">=0.8.13",
      "@tootallnate/once@<2.0.1": ">=2.0.1",
      "tmp@<0.2.6": ">=0.2.6",
      "lodash@<=4.17.23": ">=4.18.0"
    }
  }
}
